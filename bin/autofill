#!/usr/bin/env bash
# Wrapper so users run "autofill" without knowing about uv/venv.
set -euo pipefail
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  SOURCE="$(readlink "$SOURCE")"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")/.." && pwd)"
cd "$SCRIPT_DIR"
exec "${SCRIPT_DIR}/.venv/bin/python" -m autofill.agent "$@"
